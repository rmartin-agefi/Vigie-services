# Copier en .env et remplir les valeurs
# Ne jamais committer .env

# En prod : mettre à true (ou supprimer cette ligne)
AUTH_REQUIRED=false

# GCS
GCS_BUCKET=prompts-ext
GOOGLE_CLOUD_PROJECT=deft-gearbox-408209

# Admin refresh endpoint (choisir une valeur aléatoire)
ADMIN_TOKEN=

# Salesforce (OAuth2 Client Credentials flow)
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://login.salesforce.com

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Surfe
SURFE_API_KEY=

# Piano
PIANO_APP_ID_AGEFI=
PIANO_API_KEY_AGEFI=
PIANO_APP_ID_OPINION=
PIANO_API_KEY_OPINION=

# Azure AD (pour auth TODO #7)
AZURE_TENANT_ID=2e1f24be-c89e-4913-b1a1-dd9c58e71e5f
AZURE_CLIENT_ID=fa1d6eb7-fc5c-4c2b-bf27-a0fbc3b6d5e3
